# URLs the auto-gen scripts hit at build time to pull OpenAPI specs.
# When unreachable the scripts fall back to scripts/snapshots/ — the
# checked-in last-known-good versions — so builds never break offline.
GATEWAY_URL=http://gateway:8000
TABLEAU_URL=http://tableau-parser:8000
TWS_URL=http://tws-parser:8000
QLIKVIEW_URL=http://qlikview-parser:8000
SPARK_URL=http://spark-parser:8000

# Optional — used for the og:url / canonical-tag stamping when deployed.
# DOCS_PUBLIC_URL=https://docs.ariadne.example.com
