{
  "openapi": "3.1.0",
  "info": {
    "title": "spark-parser",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/version": {
      "get": {
        "summary": "Version",
        "operationId": "version_version_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Version Version Get"
                }
              }
            }
          }
        }
      }
    },
    "/parse": {
      "post": {
        "summary": "Parse",
        "operationId": "parse_parse_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Parse Parse Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/parse/project": {
      "post": {
        "summary": "Parse Project Endpoint",
        "description": "Parse a multi-file project (v0.2 §1).\n\nWalks imports from ``entry_path`` under ``project_root``, returns the\naggregated project lineage plus per-module stats and the import graph.",
        "operationId": "parse_project_endpoint_parse_project_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseProjectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Parse Project Endpoint Parse Project Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/parse/with-runtime": {
      "post": {
        "summary": "Parse With Runtime",
        "description": "Parse a script and correlate it with a Spark event log (v0.2 §11).",
        "operationId": "parse_with_runtime_parse_with_runtime_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseWithRuntimeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Parse With Runtime Parse With Runtime Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ParseProjectRequest": {
        "properties": {
          "entry_path": {
            "type": "string",
            "title": "Entry Path",
            "description": "Absolute path to the entry script"
          },
          "project_root": {
            "type": "string",
            "title": "Project Root",
            "description": "Absolute path of the project root"
          },
          "extra_search_paths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Extra Search Paths"
          },
          "max_depth": {
            "type": "integer",
            "title": "Max Depth",
            "default": 10
          },
          "neo4j_database": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Neo4J Database"
          }
        },
        "type": "object",
        "required": [
          "entry_path",
          "project_root"
        ],
        "title": "ParseProjectRequest",
        "description": "v0.2 §1 — multi-file project parse request."
      },
      "ParseRequest": {
        "properties": {
          "file_path": {
            "type": "string",
            "title": "File Path",
            "description": "Absolute path to the input file"
          },
          "language_hint": {
            "type": "string",
            "title": "Language Hint",
            "default": "auto"
          },
          "neo4j_database": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Neo4J Database"
          },
          "overwrite": {
            "type": "boolean",
            "title": "Overwrite",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "file_path"
        ],
        "title": "ParseRequest"
      },
      "ParseWithRuntimeRequest": {
        "properties": {
          "file_path": {
            "type": "string",
            "title": "File Path",
            "description": "Absolute path to the script"
          },
          "event_log_path": {
            "type": "string",
            "title": "Event Log Path",
            "description": "Path to the Spark event log dir or file"
          },
          "neo4j_database": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Neo4J Database"
          }
        },
        "type": "object",
        "required": [
          "file_path",
          "event_log_path"
        ],
        "title": "ParseWithRuntimeRequest",
        "description": "v0.2 §11 — pair a single script with a Spark event-log directory."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}