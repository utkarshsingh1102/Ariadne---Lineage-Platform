    "/files/{source}/{file_id}": {
      "delete": {
        "tags": [
          "files"
        ],
        "summary": "Delete File",
        "description": "Remove a parsed file from Neo4j along with the nodes it exclusively owns.\n\nShared label nodes (:Table, :Connection) are left intact even if this\nwas the only file referencing them — they may carry value beyond a\nsingle parse and we don't want a delete here to silently take them\nout from under another parser.",
        "operationId": "delete_file_files__source___file_id__delete",
        "parameters": [
          {
            "name": "source",
            "in": "path",
            "required": true,
            "schema": {
