    "/parse/upload/multi": {
      "post": {
        "tags": [
          "parse"
        ],
        "summary": "Parse Upload Multi",
        "description": "Accept N multipart files, save them under a shared batch directory,\nthen dispatch the parser's ``POST /parse/multi`` with the in-container\npaths. The parser merges the N units and returns shared entities +\ncross-file FOLLOWS analysis.\n\nCurrently TWS-only — other parsers can opt in by implementing their\nown ``/parse/multi`` endpoint.",
        "operationId": "parse_upload_multi_parse_upload_multi_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_parse_upload_multi_parse_upload_multi_post"
