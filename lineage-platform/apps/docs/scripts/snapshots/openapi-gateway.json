    "/parse/upload/auto": {
      "post": {
        "tags": [
          "parse"
        ],
        "summary": "Parse Upload Auto",
        "description": "Heterogeneous batch upload — accept N files of any supported types,\nclassify each by file suffix, and dispatch every file to its matching\nparser's ``/parse`` endpoint concurrently.\n\nUnlike ``/upload/multi`` (which merges N TWS files into a single\ncross-file lineage analysis), this endpoint treats each file as an\nINDEPENDENT parse and returns per-file results. The user can mix any\ncombination of Tableau, TWS, QlikView, and Spark files in a single\nupload — the system identifies the type from the extension and routes\neach to the right parser without further prompting.\n\nFiles with unrecognised suffixes are still saved + reported as\n``unsupported`` so the user sees what was skipped (no silent drops).",
        "operationId": "parse_upload_auto_parse_upload_auto_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_parse_upload_auto_parse_upload_auto_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Parse Upload Auto Parse Upload Auto Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
