# ---------------------------------------------------------------------------
# User-specified ignores
# ---------------------------------------------------------------------------
docs/
# Phase 6 exception — the Docusaurus app under lineage-platform/apps/docs/
# IS tracked. The top-level ./docs/ stays excluded. node_modules/ and
# build/ matched elsewhere in this file still apply; .docusaurus/ is a
# dev-time cache that should not be committed.
!lineage-platform/apps/docs/
!lineage-platform/apps/docs/**
lineage-platform/apps/docs/.docusaurus/
frontend-test/
qlickview-parser/
spark-improvement/
tableau-improvement/

IBM_Carbon_Design_System_Reference.md
qlikview-parser-plan.md
qlikview-tests.tar.gz
spark-parser-plan.md
spark-parser-test-report.md
spark-parser-tests.zip
tableau-parser-plan.md
tableau-parser-tests.zip
tws-parser-plan.md
tws-parser-tests.zip

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# Virtual envs
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# ANTLR generated code (regenerated from .g4 grammars by the build)
# ---------------------------------------------------------------------------
**/src/qlikview_parser/generated/*.py
!**/src/qlikview_parser/generated/__init__.py
**/src/tws_parser/generated/*.py
!**/src/tws_parser/generated/__init__.py
**/generated/*.interp
**/generated/*.tokens

